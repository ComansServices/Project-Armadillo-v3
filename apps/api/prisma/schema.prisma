generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ScanStatus {
  queued
  running
  completed
  failed
}

model Scan {
  id          String      @id
  projectId   String
  requestedBy String
  status      ScanStatus  @default(queued)
  request     Json?
  annotations Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  events      ScanEvent[]

  @@index([projectId])
  @@index([status])
  @@map("scans")
}

model ScanEvent {
  id        Int       @id @default(autoincrement())
  scanId    String
  status    ScanStatus?
  stage     String?
  message   String?
  metadata  Json?
  createdAt DateTime  @default(now())

  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId, createdAt])
  @@map("scan_events")
}

model XmlImport {
  id                    String    @id
  source                String?
  requestedBy           String
  qualityMode           String    @default("lenient")
  qualityStatus         String    @default("pass")
  alertTriggered        Boolean   @default(false)
  rootNode              String?
  itemCount             Int       @default(0)
  normalizedAssetCount  Int       @default(0)
  skippedAssetCount     Int       @default(0)
  invalidAssetCount     Int       @default(0)
  qualitySummary        Json?
  rejectArtifact        Json?
  annotations           Json?
  payload               Json
  createdAt             DateTime  @default(now())
  assets                Asset[]
  vulnerabilities       AssetVulnerability[]

  @@index([createdAt])
  @@map("xml_imports")
}

model ImportSourcePolicy {
  source                 String   @id
  enabled                Boolean  @default(true)
  defaultQualityMode     String   @default("strict")
  allowBypassToLenient   Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @default(now()) @updatedAt

  @@map("import_source_policies")
}

model Asset {
  id            String   @id
  identityKey   String   @unique
  importId      String
  ip            String?
  hostname      String?
  os            String?
  ports         Int[]    @default([])
  serviceTags   String[] @default([])
  sourceType    String   @default("xml")
  raw           Json
  annotations   Json?
  seenCount     Int      @default(1)
  firstSeenAt   DateTime @default(now())
  lastSeenAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  xmlImport       XmlImport            @relation(fields: [importId], references: [id], onDelete: Cascade)
  vulnerabilities AssetVulnerability[]

  @@index([importId, createdAt])
  @@index([ip])
  @@index([hostname])
  @@map("assets")
}

model AssetVulnerability {
  id          Int      @id @default(autoincrement())
  assetId     String
  importId    String
  cve         String
  cpe         String?
  severity    String
  cvss        Float?
  title       String?
  description String?
  source      String   @default("builtin-enricher")
  detectedAt  DateTime @default(now())

  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  xmlImport XmlImport @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@unique([assetId, cve])
  @@index([importId, severity])
  @@index([cve])
  @@map("asset_vulnerabilities")
}
