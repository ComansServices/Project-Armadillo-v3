generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ScanStatus {
  queued
  running
  completed
  failed
}

model Scan {
  id          String      @id
  projectId   String
  requestedBy String
  status      ScanStatus  @default(queued)
  request     Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  events      ScanEvent[]

  @@index([projectId])
  @@index([status])
  @@map("scans")
}

model ScanEvent {
  id        Int       @id @default(autoincrement())
  scanId    String
  status    ScanStatus?
  stage     String?
  message   String?
  metadata  Json?
  createdAt DateTime  @default(now())

  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId, createdAt])
  @@map("scan_events")
}
